// --- 1. 間違いマーク管理 ---
let wrongQuestions = JSON.parse(localStorage.getItem('wrongQuestions') || '[]');

function toggleWrongMark(qId) {
    if (wrongQuestions.includes(qId)) {
        wrongQuestions = wrongQuestions.filter(id => id !== qId);
    } else {
        wrongQuestions.push(qId);
    }
    localStorage.setItem('wrongQuestions', JSON.stringify(wrongQuestions));
    renderQuestionStatus(); // マーク表示を更新
}

// --- 2. モード選択ロジック ---
function loadMode(mode) {
    if (mode === 'random15') {
        currentQuestions = shuffleArray([...masterQuestions]).slice(0, 15);
    } else if (mode === 'wrongOnly') {
        const wrongs = masterQuestions.filter(q => wrongQuestions.includes(q.id));
        currentQuestions = shuffleArray(wrongs).slice(0, 15);
    } else {
        currentQuestions = [...masterQuestions];
    }
    currentIdx = 0;
    loadQuestion(currentIdx);
}
